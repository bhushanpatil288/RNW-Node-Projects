<section>
    <div class="container">
        <div class="blog flex py100">

            <div class="col-12">
                <div class="blog-topic text-center" style="margin-bottom: 50px;">
                    <span class="blog-sub-title">
                        Latest Blog
                    </span>
                    <h2 class="blog-title" style="font-size: 34px; margin-top: 16px; font-weight: 500;">
                        Insights & Stories from LumaFlux
                    </h2>
                </div>
            </div>

            <div class="flex gap-30" style="width: 100%; justify-content: space-between; flex-wrap: wrap;">
                
                <!-- Blog 1 -->
                <div class="col-4 col-xl-6 col-md-12 blog-contant">
                    <div class="blog-img" style="width: 100%; height: 240px; overflow: hidden;">
                        <img src="/images/<%= blog1 %>" alt="Blog Post 1" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div class="blog-bottom" style="padding: 24px;">
                        <h3 class="blog-bottom-title" style="font-size: 20px; font-weight: 700; color: var(--text-color);">
                            Designing visual systems for digital products
                        </h3>
                        <p class="blog-bottom-sub-title" style="margin: 12px 0 20px; font-size: 15px; line-height: 1.5; color: var(--text-color-2);">
                            Discover how to build scaleable UI components and design tokens that work for any team.
                        </p>
                        <h4 class="blog-bottom-link" style="color: var(--primary); font-weight: 600; font-size: 16px; display: inline-flex; align-items: center;">
                            Read More
                            <i class="ri-arrow-right-line" style="margin-left: 6px;"></i>
                        </h4>
                    </div>
                </div>

                <!-- Blog 2 -->
                <div class="col-4 col-xl-6 col-md-12 blog-contant">
                    <div class="blog-img" style="width: 100%; height: 240px; overflow: hidden;">
                        <img src="/images/<%= blog2 %>" alt="Blog Post 2" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div class="blog-bottom" style="padding: 24px;">
                        <h3 class="blog-bottom-title" style="font-size: 20px; font-weight: 700; color: var(--text-color);">
                            Clarity in modern web interfaces
                        </h3>
                        <p class="blog-bottom-sub-title" style="margin: 12px 0 20px; font-size: 15px; line-height: 1.5; color: var(--text-color-2);">
                            Why minimalist layouts and subtle animations drive better engagement and higher conversions.
                        </p>
                        <h4 class="blog-bottom-link" style="color: var(--primary); font-weight: 600; font-size: 16px; display: inline-flex; align-items: center;">
                            Read More
                            <i class="ri-arrow-right-line" style="margin-left: 6px;"></i>
                        </h4>
                    </div>
                </div>

                <!-- Blog 3 -->
                <div class="col-4 col-xl-6 col-md-12 blog-contant">
                    <div class="blog-img" style="width: 100%; height: 240px; overflow: hidden;">
                        <img src="/images/<%= blog3 %>" alt="Blog Post 3" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div class="blog-bottom" style="padding: 24px;">
                        <h3 class="blog-bottom-title" style="font-size: 20px; font-weight: 700; color: var(--text-color);">
                            Fast iteration and product strategy
                        </h3>
                        <p class="blog-bottom-sub-title" style="margin: 12px 0 20px; font-size: 15px; line-height: 1.5; color: var(--text-color-2);">
                            How LumaFlux helps teams transition from mockups to launch-ready code in record time.
                        </p>
                        <h4 class="blog-bottom-link" style="color: var(--primary); font-weight: 600; font-size: 16px; display: inline-flex; align-items: center;">
                            Read More
                            <i class="ri-arrow-right-line" style="margin-left: 6px;"></i>
                        </h4>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>