                                120K
                            </h2>

                            <h2 class="since-users">
                                Projects <br>
                                Already Done
                            </h2>
                        </div>

                    </div>

                </div>

            </div>

            <!-- Right Side -->
            <div class="col-6 col-lg-12">

                <!-- Review 1 -->
                <div class="review">

                    <div class="review-top flex">

                        <div class="user-img-name flex align-center">
