<section class="contact-section">
    <div class="container">
        <div class="contact-top text-center" style="margin-bottom: 50px;">
            <span class="features-sub-title contact-sub-title">Get In Touch</span>
            <h2 class="contact-title" style="font-size: 34px; margin-top: 16px; font-weight: 500;">Let's build something bold.</h2>
            <p class="contact-desc" style="color: var(--text-color-3); margin-top: 8px;">Have questions or ready to launch? Drop us a message.</p>
        </div>

        <div class="contact-wrapper flex" style="display: flex; gap: 30px; align-items: stretch; flex-wrap: wrap;">
            <!-- Info Box -->
            <div class="col-5 col-lg-12" style="flex: 1 1 350px;">
                <div class="contact-info">
                    <div class="info-box">
                        <i class="ri-mail-line"></i>
                        <div>
                            <h3>Email Us</h3>
                            <p>hello@lumaflux.com</p>
                        </div>
                    </div>
                    <div class="info-box">
                        <i class="ri-map-pin-line"></i>
                        <div>
                            <h3>Our Studio</h3>
                            <p>San Francisco, CA</p>
                        </div>
                    </div>
                    <div class="info-box">
                        <i class="ri-phone-line"></i>
                        <div>
                            <h3>Call Us</h3>
                            <p>+1 (555) 019-2834</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Box -->
            <div class="col-7 col-lg-12" style="flex: 2 1 450px;">
                <div class="contact-form">
                    <form action="/email" method="POST">
                        <div class="form-group">
                            <input type="text" placeholder="Your Name" required>
                        </div>
                        <div class="form-group">
                            <input type="email" name="email" placeholder="Your Email" required>
                        </div>
                        <div class="form-group">
                            <textarea rows="5" placeholder="Your Message" required style="resize: vertical; min-height: 120px;"></textarea>
                        </div>
                        <button type="submit" class="contact-btn">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
