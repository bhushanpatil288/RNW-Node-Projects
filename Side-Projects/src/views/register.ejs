<%- include('partials/head', { title: 'Register' }) %>
<%- include('partials/navbar', {
    eyebrow: 'Practice Project',
    title: 'Create an Account',
    showAddProduct: false,
    showAuthAction: false,
    authHref: '/auth/login',
    authLabel: 'Sign In'
}) %>

<main class="mx-auto flex min-h-[calc(100vh-180px)] max-w-7xl items-center justify-center px-4 py-12 sm:px-6 lg:px-8">
        <section class="w-full max-w-md rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-600">Join Us</p>
            <h2 class="mt-4 text-3xl font-semibold text-slate-900">Register a new account</h2>
            <p class="mt-3 text-base text-slate-600">
                Create your account to unlock product browsing and protected features.
            </p>

            <form action="/auth/register" method="POST" class="mt-8 space-y-5">
                <div class="flex flex-col gap-2">
                    <label for="username" class="text-sm font-medium text-slate-700">Name</label>
                    <input type="text" name="username" id="username" class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white" />
                </div>

                <div class="flex flex-col gap-2">
                    <label for="email" class="text-sm font-medium text-slate-700">Email</label>
                    <input type="email" name="email" id="email" class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white" />
                </div>

                <div class="flex flex-col gap-2">
                    <label for="password" class="text-sm font-medium text-slate-700">Password</label>
                    <input type="password" name="password" id="password" class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white" />
                </div>

                <button class="w-full rounded-xl bg-slate-900 px-4 py-3 font-medium text-white transition hover:bg-slate-700">
                    Create Account
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-slate-600">
                Already have an account?
                <a href="/auth/login" class="ml-1 font-semibold text-emerald-600 transition hover:text-emerald-500">Login now</a>
            </p>
        </section>
    </main>

<%- include('partials/footer', { message: 'Build your account with the same polished experience as the rest of the app.' }) %>