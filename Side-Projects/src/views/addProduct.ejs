<%- include('partials/head', { title: 'Add Product' }) %>

<%- include('partials/sidebar', { activePage: 'addProduct' }) %>
<%- include('partials/header', { user: typeof user !== 'undefined' ? user : null }) %>

  <!-- ========== section start ========== -->
  <section class="section">
    <div class="container-fluid">
      <div class="title-wrapper pt-30">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="title">
              <h2>Add Product</h2>
            </div>
          </div>
          <div class="col-md-6">
            <div class="breadcrumb-wrapper">
              <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                  <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                  <li class="breadcrumb-item"><a href="/products">Products</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Add Product</li>
                </ol>
              </nav>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-lg-8">
          <div class="card-style mb-30">
            <h6 class="mb-25">Product Information</h6>
            <form action="/products/add" method="POST" enctype="multipart/form-data">
              <div class="row">
                <div class="col-12">
                  <div class="input-style-1">
                    <label>Product Title</label>
                    <input type="text" name="title" placeholder="Enter product title" required />
                  </div>
                </div>
                <div class="col-12">
                  <div class="input-style-1">
                    <label>Description</label>
                    <textarea name="description" placeholder="Enter product description" rows="4"></textarea>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="input-style-1">
                    <label>Price ($)</label>
                    <input type="number" name="price" min="0" step="0.01" placeholder="0.00" required />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="input-style-1">
                    <label>Category</label>
                    <input type="text" name="category" placeholder="Enter category name" required />
                  </div>
                </div>
                <div class="col-12">
                  <div class="input-style-1">
                    <label>Product Image</label>
                    <input type="file" name="productImg" required />
                  </div>
                </div>
                <div class="col-12">
                  <div class="button-group d-flex justify-content-end flex-wrap pt-15">
                    <a href="/products" class="main-btn light-btn btn-hover me-3">Cancel</a>
                    <button type="submit" class="main-btn primary-btn btn-hover">Save Product</button>
                  </div>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ========== section end ========== -->

<%- include('partials/footer') %>
