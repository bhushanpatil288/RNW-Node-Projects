<%- include('partials/head', { title: 'Add Product' }) %>
<%- include('partials/navbar', {
  eyebrow: 'Product Manager',
  title: 'Add a New Product',
  showAddProduct: false,
  showAuthAction: false,
  authHref: '/auth/login',
  authLabel: 'Sign In'
}) %>

<main class="mx-auto flex min-h-[calc(100vh-220px)] max-w-7xl items-center justify-center px-4 py-12 sm:px-6 lg:px-8">
  <section class="w-full max-w-2xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-600">New Listing</p>
    <h2 class="mt-4 text-3xl font-semibold text-slate-900">Create a product card</h2>
    <p class="mt-3 text-base text-slate-600">
      Add a polished product entry with an image, price, and description for the storefront.
    </p>

    <form action="/products/add" method="POST" enctype="multipart/form-data" class="mt-8 space-y-5">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="flex flex-col gap-2 md:col-span-2">
          <label for="title" class="text-sm font-medium text-slate-700">Product Title</label>
          <input type="text" name="title" id="title" required class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white" />
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label for="description" class="text-sm font-medium text-slate-700">Description</label>
          <textarea name="description" id="description" rows="4" class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white"></textarea>
        </div>

        <div class="flex flex-col gap-2">
          <label for="price" class="text-sm font-medium text-slate-700">Price</label>
          <input type="number" name="price" id="price" min="0" step="0.01" required class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white" />
        </div>

        <div class="flex flex-col gap-2">
          <label for="productImg" class="text-sm font-medium text-slate-700">Image</label>
          <input type="file" name="productImg" id="productImg" required class="rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-slate-700 outline-none transition focus:border-emerald-500 focus:bg-white" />
        </div>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
        <a href="/products" class="rounded-xl border border-slate-300 px-5 py-3 text-center text-sm font-medium text-slate-700 transition hover:bg-slate-100">Cancel</a>
        <button type="submit" class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700">Save Product</button>
      </div>
    </form>
  </section>
</main>

<%- include('partials/footer', { message: 'Add new products with the same polished experience as the storefront.' }) %>
