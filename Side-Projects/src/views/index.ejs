<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Practice Store</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">
    <header class="bg-slate-900 text-white">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-6 sm:px-6 lg:px-8">
            <div>
                <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Practice Project</p>
                <h1 class="text-2xl font-semibold sm:text-3xl">Practice Store</h1>
            </div>
            <% if (isLoggedIn) { %>
                <a href="/products" class="rounded-full border border-emerald-600 bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-emerald-500">
                    View Products
                </a>
            <% } else { %>
                <a href="/auth/login" class="rounded-full border border-slate-700 px-4 py-2 text-sm font-medium transition hover:bg-slate-800">
                    Sign In / Log In
                </a>
            <% } %>
        </div>
    </header>

    <main class="mx-auto flex max-w-7xl flex-col items-center px-4 py-16 text-center sm:px-6 lg:px-8">
        <div class="max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-12">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-600">Auth + Products Demo</p>
            <h2 class="mt-4 text-3xl font-semibold text-slate-900 sm:text-5xl">
                Sign in, browse products, and add what you love.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600">
                This is a simple practice project built to learn authentication, protected routes, and product browsing with a modern UI.
            </p>

            <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
                <a href="/auth/login" class="rounded-xl bg-slate-900 px-6 py-3 font-medium text-white transition hover:bg-slate-700">
                    Get Started
                </a>
                <a href="/products" class="rounded-xl border border-slate-300 px-6 py-3 font-medium text-slate-700 transition hover:bg-slate-100">
                    View Products
                </a>
            </div>
        </div>
    </main>

    <footer class="border-t border-slate-200 bg-white/80 py-6">
        <div class="mx-auto max-w-7xl px-4 text-center text-sm text-slate-500 sm:px-6 lg:px-8">
            This is a practice project for learning sign-in and login flow, product viewing, and adding items to a cart.
        </div>
    </footer>
</body>
</html>