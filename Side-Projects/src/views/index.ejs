<%- include('partials/head', { title: 'Practice Store' }) %>
<%- include('partials/navbar', {
    eyebrow: 'Practice Project',
    title: 'Practice Store',
    showAddProduct: isLoggedIn,
    showAuthAction: !isLoggedIn,
    authHref: '/auth/login',
    authLabel: 'Sign In / Log In'
}) %>

<main class="mx-auto flex max-w-7xl flex-col items-center px-4 py-16 text-center sm:px-6 lg:px-8">
        <div class="max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-12">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-600">Auth + Products Demo</p>
            <h2 class="mt-4 text-3xl font-semibold text-slate-900 sm:text-5xl">
                Sign in, browse products, and add what you love.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600">
                This is a simple practice project built to learn authentication, protected routes, and product browsing with a modern UI.
            </p>

            <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
                <a href="/auth/login" class="rounded-xl bg-slate-900 px-6 py-3 font-medium text-white transition hover:bg-slate-700">
                    Get Started
                </a>
                <a href="/products" class="rounded-xl border border-slate-300 px-6 py-3 font-medium text-slate-700 transition hover:bg-slate-100">
                    View Products
                </a>
            </div>
        </div>
    </main>

<%- include('partials/footer', { message: 'This is a practice project for learning sign-in and login flow, product viewing, and adding items to a cart.' }) %>