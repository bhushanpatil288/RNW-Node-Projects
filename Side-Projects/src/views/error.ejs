<%- include('partials/head', { title: 'Error ' + status }) %>

<body class="min-h-screen bg-blue-50 flex items-top justify-center p-6">

    <div class=" w-full rounded-2xl bg-white shadow-xl border border-blue-200 p-8">

        <h1 class="text-4xl font-bold text-red-600">
            Error <%= status %>
        </h1>

        <p class="mt-4 text-lg text-slate-700">
            <%= message %>
        </p>

        <% if (stack) { %>
            <div class="mt-8">
                <h2 class="font-semibold text-slate-800 mb-2">
                    Stack Trace
                </h2>

                <pre class="overflow-auto rounded-lg bg-slate-900 text-green-400 p-4 text-sm"><%= stack %></pre>
            </div>
        <% } %>

    </div>

<%- include('partials/footer', { message: 'Please return to the home page and try again.' }) %>