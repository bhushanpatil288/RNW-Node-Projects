<%- include('partials/head', { title: 'Profile' }) %>

<%- include('partials/sidebar', { activePage: 'profile' }) %>
<%- include('partials/header', { user: typeof user !== 'undefined' ? user : null }) %>

  <!-- ========== section start ========== -->
  <section class="section">
    <div class="container-fluid">
      <div class="title-wrapper pt-30">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="title">
              <h2>Profile</h2>
            </div>
          </div>
          <div class="col-md-6">
            <div class="breadcrumb-wrapper">
              <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                  <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Profile</li>
                </ol>
              </nav>
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <!-- ========== User Info Card ========== -->
        <div class="col-lg-4">
          <div class="card-style mb-30">
            <div class="text-center">
              <div class="mb-20">
                <img src="/assets/images/profile/profile-image.png" alt="Profile" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;" />
              </div>
              <h5><%= user?.username || 'N/A' %></h5>
              <p class="text-sm text-gray"><%= user?.email || 'N/A' %></p>
              <hr />
              <div class="text-start">
                <p class="text-sm mb-10"><strong>User ID:</strong></p>
                <p class="text-sm text-gray" style="word-break: break-all;"><%= user?.id || 'N/A' %></p>
              </div>
              <div class="text-start mt-15">
                <p class="text-sm mb-10"><strong>Member Since:</strong></p>
                <p class="text-sm text-gray"><%= user?.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A' %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== Reset Password Form ========== -->
        <div class="col-lg-8">
          <div class="card-style mb-30">
            <h6 class="mb-25">Reset Password</h6>
            <p class="text-sm text-gray mb-25">An OTP will be sent to your email to verify the password change.</p>
            <form action="/auth/reset-password" method="POST">
              <div class="row">
                <div class="col-12">
                  <div class="input-style-1">
                    <label>Current Password</label>
                    <input type="password" name="passwordOld" placeholder="Enter current password" required />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="input-style-1">
                    <label>New Password</label>
                    <input type="password" name="passwordNew" placeholder="Enter new password" required />
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="input-style-1">
                    <label>Confirm New Password</label>
                    <input type="password" name="passwordConfirm" placeholder="Confirm new password" required />
                  </div>
                </div>
                <div class="col-12">
                  <div class="button-group d-flex justify-content-end flex-wrap">
                    <button type="submit" class="main-btn success-btn btn-hover">Reset Password</button>
                  </div>
                </div>
              </div>
            </form>
          </div>

          <!-- ========== Quick Actions ========== -->
          <div class="card-style mb-30">
            <h6 class="mb-25">Quick Actions</h6>
            <div class="d-flex flex-wrap gap-3">
              <a href="/products" class="main-btn primary-btn btn-sm btn-hover">View Products</a>
              <a href="/products/add" class="main-btn light-btn btn-sm btn-hover">Add Product</a>
              <a href="/auth/logout" class="main-btn danger-btn btn-sm btn-hover">Logout</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ========== section end ========== -->

<%- include('partials/footer') %>