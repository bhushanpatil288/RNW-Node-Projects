<%- include('partials/head', { title: 'OTP Verification' }) %>

<%- include('partials/sidebar', { activePage: 'profile' }) %>
<%- include('partials/header', { user: typeof user !== 'undefined' ? user : null }) %>

  <!-- ========== section start ========== -->
  <section class="section">
    <div class="container-fluid">
      <div class="title-wrapper pt-30">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="title">
              <h2>OTP Verification</h2>
            </div>
          </div>
          <div class="col-md-6">
            <div class="breadcrumb-wrapper">
              <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                  <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                  <li class="breadcrumb-item"><a href="/user/profile">Profile</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Verify OTP</li>
                </ol>
              </nav>
            </div>
          </div>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-lg-6">
          <div class="card-style mb-30">
            <div class="text-center mb-25">
              <div class="mb-15" style="font-size: 48px; color: #4f46e5;">
                <i class="lni lni-lock-alt"></i>
              </div>
              <h5>Enter Verification Code</h5>
              <p class="text-sm text-gray mt-10">We've sent an OTP to your email. Enter it below to confirm your password reset.</p>
            </div>
            <form action="/auth/verify-otp" method="POST">
              <div class="row">
                <div class="col-12">
                  <div class="input-style-1">
                    <label>OTP Code</label>
                    <input type="number" name="otp" placeholder="Enter 4-digit OTP" required style="text-align: center; font-size: 24px; letter-spacing: 8px;" />
                  </div>
                </div>
                <div class="col-12">
                  <div class="button-group d-flex justify-content-center flex-wrap">
                    <button type="submit" class="main-btn primary-btn btn-hover w-100 text-center">
                      Verify OTP
                    </button>
                  </div>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ========== section end ========== -->

<%- include('partials/footer') %>