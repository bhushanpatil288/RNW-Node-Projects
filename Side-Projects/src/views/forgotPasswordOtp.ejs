<%- include('partials/head', { title: 'Verify OTP' }) %>

<%- include('partials/sidebar', { activePage: '' }) %>
<%- include('partials/header', { user: null }) %>

  <!-- ========== section start ========== -->
  <section class="signin-section">
    <div class="container-fluid">
      <div class="title-wrapper pt-30">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="title">
              <h2>Verify OTP</h2>
            </div>
          </div>
          <div class="col-md-6">
            <div class="breadcrumb-wrapper">
              <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                  <li class="breadcrumb-item"><a href="/">Home</a></li>
                  <li class="breadcrumb-item"><a href="/auth/forgot-password">Forgot Password</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Verify OTP</li>
                </ol>
              </nav>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-0 auth-row">
        <div class="col-lg-6">
          <div class="auth-cover-wrapper bg-primary-100">
            <div class="auth-cover">
              <div class="title text-center">
                <h1 class="text-primary mb-10">Verify & Reset</h1>
                <p class="text-medium">
                  Enter the OTP and set your new password
                </p>
              </div>
              <div class="cover-image">
                <img src="/assets/images/auth/signin-image.svg" alt="" />
              </div>
              <div class="shape-image">
                <img src="/assets/images/auth/shape.svg" alt="" />
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="signin-wrapper">
            <div class="form-wrapper">
              <h6 class="mb-15">OTP Verification</h6>
              <p class="text-sm mb-25">
                We've sent a 4-digit code to <strong><%= typeof email !== 'undefined' ? email : 'your email' %></strong>. Enter the code along with your new password below.
              </p>
              <form action="/auth/forgot-password/verify" method="POST">
                <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" />
                <div class="row">
                  <div class="col-12">
                    <div class="input-style-1">
                      <label>OTP Code</label>
                      <input type="number" name="otp" placeholder="Enter 4-digit OTP" required style="text-align: center; font-size: 24px; letter-spacing: 8px;" />
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="input-style-1">
                      <label>New Password</label>
                      <input type="password" name="newPassword" placeholder="Enter your new password" required />
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="input-style-1">
                      <label>Confirm Password</label>
                      <input type="password" name="confirmPassword" placeholder="Confirm your new password" required />
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="button-group d-flex justify-content-center flex-wrap">
                      <button class="main-btn primary-btn btn-hover w-100 text-center">
                        Reset Password
                      </button>
                    </div>
                  </div>
                </div>
              </form>
              <div class="singin-option pt-40">
                <p class="text-sm text-medium text-dark text-center">
                  Didn't receive the code?
                  <a href="/auth/forgot-password">Resend OTP</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ========== section end ========== -->

<%- include('partials/footer') %>
