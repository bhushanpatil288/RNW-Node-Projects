<header class="bg-slate-900 text-white">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-6 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <div>
      <p class="text-sm uppercase tracking-[0.3em] text-slate-400"><%= eyebrow %></p>
      <h1 class="text-2xl font-semibold sm:text-3xl"><%= title %></h1>
    </div>

    <nav class="flex flex-wrap items-center gap-3">
      <a href="/" class="rounded-full border border-slate-700 px-4 py-2 text-sm font-medium transition hover:bg-slate-800">
        Home
      </a>
      <a href="/products" class="rounded-full border border-slate-700 px-4 py-2 text-sm font-medium transition hover:bg-slate-800">
        Products
      </a>
      <% if (showAddProduct) { %>
        <a href="/products/add" class="inline-flex items-center gap-2 rounded-full border border-emerald-600 bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-emerald-500">
          <span class="text-base">+</span>
          Add Product
        </a>
        <a href="/user/profile" class="rounded-full border border-slate-700 px-4 py-2 text-sm font-medium transition hover:bg-slate-800">
          Profile
        </a>
      <% } %>
      <% if (showAuthAction) { %>
        <a href="<%= authHref %>" class="rounded-full border border-slate-700 px-4 py-2 text-sm font-medium transition hover:bg-slate-800">
          <%= authLabel %>
        </a>
      <% } %>
    </nav>
  </div>
</header>
