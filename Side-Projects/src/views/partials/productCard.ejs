<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
  <img src="<%= product.productImg || product.img %>" alt="<%= product.title %>" class="h-48 w-full object-cover" />
  <div class="p-5">
    <h3 class="text-lg font-semibold text-slate-900"><%= product.title %></h3>
    <p class="mt-2 text-sm leading-6 text-slate-600"><%= product.description %></p>

    <div class="mt-4 flex items-center justify-between">
      <span class="text-xl font-bold text-emerald-600">$<%= product.price %></span>
      <span class="text-sm text-slate-500">Free shipping</span>
    </div>

    <div class="mt-5 flex flex-col gap-3 sm:flex-row">
      <button class="flex-1 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700">
        Buy Now
      </button>
      <button class="flex-1 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">
        Add to Cart
      </button>
    </div>
  </div>
</article>
