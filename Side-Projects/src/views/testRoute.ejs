<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Server Online</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen select-none bg-gradient-to-br from-blue-50 via-sky-50 to-blue-100 flex items-center justify-center p-6">

  <div class="w-full max-w-2xl rounded-3xl border border-blue-200 bg-white/90 backdrop-blur shadow-2xl shadow-blue-200/40">

    <div class="p-10 text-center">

      <div class="text-7xl mb-6">🖥️</div>

      <span class="inline-flex items-center gap-2 rounded-full bg-green-100 px-4 py-2 text-sm font-semibold text-green-700">
        <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
        Server Online
      </span>

      <h1 class="mt-6 text-4xl font-bold text-blue-700">
        Express Server is Running
      </h1>

      <p class="mt-4 text-slate-600 leading-7">
        Your Express application is running successfully. This page confirms that
        your server, routing, and view engine are working correctly.
      </p>

      <div class="mt-8 rounded-2xl border border-blue-100 bg-blue-50 p-6 text-left">
        <div class="grid gap-4 sm:grid-cols-2">

          <div>
            <p class="text-xs uppercase tracking-wide text-slate-500">
              Status
            </p>
            <p class="mt-1 font-semibold text-green-600">
              200 OK
            </p>
          </div>

          <div>
            <p class="text-xs uppercase tracking-wide text-slate-500">
              Environment
            </p>
            <p class="mt-1 font-semibold text-slate-700">
              Development
            </p>
          </div>

          <div>
            <p class="text-xs uppercase tracking-wide text-slate-500">
              View Engine
            </p>
            <p class="mt-1 font-semibold text-slate-700">
              EJS ✓
            </p>
          </div>

          <div>
            <p class="text-xs uppercase tracking-wide text-slate-500">
              Health
            </p>
            <p class="mt-1 font-semibold text-green-600">
              Healthy
            </p>
          </div>

        </div>
      </div>

      <div class="mt-8 border-t border-blue-100 pt-6 text-sm text-slate-500">
        🚀 Everything is configured correctly.
      </div>

    </div>

  </div>

</body>
</html>