<%- include('partials/header') %>

<%- include('partials/navbar') %>

<main>
    <div class="container page-padding">
        <div class="form-container">
            <div class="form-header">
                <h2 class="form-title">Verify OTP</h2>
                <p class="form-subtitle">Enter the 4-digit verification code sent to your email</p>
            </div>

            <form method="POST" action="/verify-otp" class="form-wrapper">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-banner" style="background-color: rgba(220, 38, 38, 0.2); border: 1px solid #dc2626; color: #fca5a5; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= error %>
                    </div>
                <% } else if (typeof errorMessages !== 'undefined' && errorMessages.length > 0) { %>
                    <div class="error-banner" style="background-color: rgba(220, 38, 38, 0.2); border: 1px solid #dc2626; color: #fca5a5; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= errorMessages[0] %>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="success-banner" style="background-color: rgba(74, 124, 89, 0.2); border: 1px solid var(--accent-green); color: #a7f3d0; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= success %>
                    </div>
                <% } else if (typeof successMessages !== 'undefined' && successMessages.length > 0) { %>
                    <div class="success-banner" style="background-color: rgba(74, 124, 89, 0.2); border: 1px solid var(--accent-green); color: #a7f3d0; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= successMessages[0] %>
                    </div>
                <% } %>

                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label for="otp" class="form-label">One-Time Password (OTP) *</label>
                    <input 
                        type="text" 
                        id="otp" 
                        name="otp" 
                        required
                        maxlength="4"
                        placeholder="1234"
                        style="text-align: center; font-size: 1.5rem; letter-spacing: 0.5rem; font-weight: bold;"
                        class="form-input"
                    />
                </div>

                <div style="background-color: rgba(74, 124, 89, 0.1); border: 1px solid rgba(74, 124, 89, 0.3); border-radius: 6px; padding: 0.75rem; text-align: center; margin-bottom: 2rem; font-size: 0.85rem; color: var(--text-secondary);">
                    Hint: Use OTP <strong style="color: var(--accent-green);"><%= typeof staticOtp !== 'undefined' ? staticOtp : '1234' %></strong> for testing.
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <button type="submit" class="btn btn-primary btn-block">Verify OTP</button>
                </div>
                
                <div style="text-align: center; font-size: 0.9rem; color: var(--text-secondary);">
                    Back to <a href="/login" style="color: var(--accent-green); text-decoration: none; font-weight: 500;">Sign In</a>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
