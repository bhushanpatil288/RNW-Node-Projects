<%- include('partials/header') %>

<%- include('partials/navbar') %>

<main>
    <div class="container page-padding">
        <div class="form-container">
            <div class="form-header">
                <h2 class="form-title">Create Account</h2>
                <p class="form-subtitle">Join us to organize your movie library</p>
            </div>

            <form method="POST" action="/signup" class="form-wrapper">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-banner" style="background-color: rgba(220, 38, 38, 0.2); border: 1px solid #dc2626; color: #fca5a5; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= error %>
                    </div>
                <% } else if (typeof errorMessages !== 'undefined' && errorMessages.length > 0) { %>
                    <div class="error-banner" style="background-color: rgba(220, 38, 38, 0.2); border: 1px solid #dc2626; color: #fca5a5; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= errorMessages[0] %>
                    </div>
                <% } %>

                <div class="form-group">
                    <label for="username" class="form-label">Username *</label>
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        required
                        value="<%= typeof username !== 'undefined' ? username : '' %>"
                        placeholder="Choose a username"
                        class="form-input"
                    />
                </div>

                <div class="form-group">
                    <label for="email" class="form-label">Email Address *</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required
                        value="<%= typeof email !== 'undefined' ? email : '' %>"
                        placeholder="name@example.com"
                        class="form-input"
                    />
                </div>

                <div class="form-group" style="margin-bottom: 2rem;">
                    <label for="password" class="form-label">Password *</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        required
                        placeholder="At least 6 characters"
                        class="form-input"
                    />
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <button type="submit" class="btn btn-primary btn-block">Sign Up</button>
                </div>
                
                <div style="text-align: center; font-size: 0.9rem; color: var(--text-secondary);">
                    Already have an account? <a href="/login" style="color: var(--accent-green); text-decoration: none; font-weight: 500; transition: color 0.2s ease;">Sign In</a>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
