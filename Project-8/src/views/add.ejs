<%- include('partials/header') %>

<%- include('partials/navbar') %>

<main>
    <div class="container page-padding">
        <div class="form-container">
            <div class="form-header">
                <h2 class="form-title">Create New Blog</h2>
                <p class="form-subtitle">Complete the form below to publish a blog post</p>
            </div>

            <form method="POST" action="/add" class="form-wrapper" enctype="multipart/form-data">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-banner" style="background-color: rgba(220, 38, 38, 0.2); border: 1px solid #dc2626; color: #fca5a5; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.95rem; text-align: center;">
                        <%= error %>
                    </div>
                <% } %>
                <div class="form-group">
                    <label for="title" class="form-label">Blog Title *</label>
                    <input 
                        type="text" 
                        id="title" 
                        name="title" 
                        required
                        placeholder="Enter blog title"
                        class="form-input"
                    />
                </div>

                <div class="form-group">
                    <label for="author" class="form-label">Author Name *</label>
                    <input 
                        type="text" 
                        id="author" 
                        name="author" 
                        required
                        placeholder="Author name"
                        class="form-input"
                    />
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label for="readTime" class="form-label">Read Time (mins) *</label>
                        <input 
                            type="number" 
                            id="readTime" 
                            name="readTime" 
                            required
                            min="1"
                            max="600"
                            placeholder="5"
                            class="form-input"
                        />
                    </div>
                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label for="category" class="form-label">Category *</label>
                        <select 
                            id="category" 
                            name="category" 
                            required
                            class="form-select"
                        >
                            <option value="">Select Category</option>
                            <option value="Technology">Technology</option>
                            <option value="Lifestyle">Lifestyle</option>
                            <option value="Travel">Travel</option>
                            <option value="Food">Food</option>
                            <option value="Fashion">Fashion</option>
                            <option value="Business">Business</option>
                            <option value="Health">Health</option>
                            <option value="Education">Education</option>
                            <option value="Other">Other</option>
                        </select>
                </div>

                <div class="form-group" style="margin-bottom: 2rem;">
                    <label for="content" class="form-label">Content *</label>
                    <textarea 
                        id="content" 
                        name="content" 
                        required
                        placeholder="Enter blog content..."
                        rows="6"
                        class="form-textarea"
                    ></textarea>
                </div>

                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label for="image" class="form-label">Blog Image *</label>
                    <input 
                        type="file" 
                        id="image" 
                        name="image"
                        required
                        accept="image/*"
                        class="form-input"
                    />
                </div>

                <div class="btn-group">
                    <button type="submit" class="btn btn-primary">Publish Blog</button>
                    <a href="/" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('partials/footer') %>