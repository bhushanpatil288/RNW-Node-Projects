<div class="blog-card" onclick="openBlogModal(this)"
     data-title="<%= blog.title %>"
     data-author="<%= blog.author %>"
     data-category="<%= blog.category %>"
     data-read-time="<%= blog.readTime ? blog.readTime + ' mins read' : '' %>"
     data-published-by="<%= (blog.user && blog.user.username) ? blog.user.username : 'Unknown' %>"
     data-image="<%= blog.image || '' %>">
    
    <div class="blog-card-header">
        <% if (typeof blog.image !== 'undefined' && blog.image) { %>
            <img src="<%= blog.image %>" alt="<%= blog.title %>" style="width: 100%; height: 100%; object-fit: cover;">
        <% } else { %>
            📝
        <% } %>
    </div>
    <div class="blog-card-body">
        <h3 class="blog-card-title"><%= blog.title %></h3>
        <div class="blog-card-info">
            <p class="blog-card-info-item">
                <span class="blog-card-info-label">Author</span><br/><%= blog.author || '—' %>
            </p>
            <p class="blog-card-info-item">
                <span class="blog-card-info-label">Read Time</span><br/><%= blog.readTime ? blog.readTime + ' mins' : '—' %>
            </p>
            <p class="blog-card-info-item">
                <span class="blog-card-info-label">Category</span><br/><%= blog.category || '—' %>
            </p>
            <p class="blog-card-info-item">
                <span class="blog-card-info-label">Published By</span><br/><%= (blog.user && blog.user.username) ? blog.user.username : 'Unknown' %>
            </p>
        </div>
        <p class="blog-card-description">
            <%= typeof blog.content !== 'undefined' ? (blog.content.length > 90 ? blog.content.substring(0, 90) + '...' : blog.content) : 'No content available' %>
        </p>
        
        <!-- Hidden full content storage for modal retrieval -->
        <div class="blog-card-hidden-content" style="display: none;"><%= blog.content %></div>

        <div class="blog-card-actions">
            <a href="/edit/<%= blog._id || '#' %>" onclick="event.stopPropagation();" class="btn btn-primary">Edit</a>
            <a href="/delete/<%= blog._id || '#' %>" onclick="event.stopPropagation();" class="btn btn-secondary">Delete</a>
        </div>
    </div>
</div>
